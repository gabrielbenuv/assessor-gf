# ===== Banco de dados =====
# LOCAL (sem Docker): SQLite
DATABASE_URL="file:./dev.db"
# PRODUÇÃO (EasyPanel / Postgres): troque tambem o provider em prisma/schema.prisma para "postgresql"
# DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/assessor?schema=public"

# ===== Segurança =====
# Chave usada para assinar a sessão e criptografar as chaves de API guardadas no banco.
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET="troque-isto-por-uma-chave-aleatoria-de-64-hex"

# Login do painel
ADMIN_EMAIL="admin@assessor.local"
ADMIN_PASSWORD="admin123"

# ===== Fuso / app =====
TZ="America/Sao_Paulo"
APP_URL="http://localhost:3000"

# ===== Integrações (opcional aqui — podem ser preenchidas pelo painel em /integracoes) =====
# OPENAI_API_KEY=""
# EVOLUTION_API_URL=""
# EVOLUTION_API_KEY=""
# EVOLUTION_INSTANCE=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
